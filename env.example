# ============================================
# SPYNET — VARIÁVEIS DE AMBIENTE
# Copie este arquivo para .env e preencha os valores
# NUNCA commite o .env no GitHub!
# ============================================

# Telegram Bot (obtenha em @BotFather)
BOT_TOKEN=SEU_TOKEN_AQUI
CHAT_ID=SEU_CHAT_ID_AQUI

# Sentinel Ultimate - credenciais de acesso ao painel local
SENTINEL_USER=admin
SENTINEL_SENHA=SUA_SENHA_AQUI

# URL do servidor no Render (para cliente_local.py)
SERVIDOR_URL=https://sentinel-monitor.onrender.com

# SPYNET Web (Render) — configure no painel do Render, não aqui
# SECRET_KEY=
# ADMIN_USER=
# ADMIN_PASS=
# SISTEMA_SENHA=
# INVESTIGADOR=
# ADMIN_SENHA=
# ADMIN_SECRET_KEY=
